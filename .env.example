# Server
PORT=3000

# Admin email — recipient of analytics notifications
ADMIN_EMAIL=admin@yourdomain.com

# SMTP configuration (example: Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false          # true for port 465, false for 587 (STARTTLS)
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password  # Gmail: use an App Password, not your account password

# Display name shown in the "From" field
SMTP_FROM_NAME=Analytics Bot
